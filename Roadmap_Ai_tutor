Database Schema — Full 7-Phase Model
Design the full schema now. Adding columns later with ALTER TABLE on live data is risky. Every table below is used in a specific phase — do not skip any.

-- users: all roles share one table, role field gates access
CREATE TABLE users (
  id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  email       TEXT UNIQUE NOT NULL,
  role        TEXT CHECK(role IN ('student','parent','admin')),
  created_at  TIMESTAMPTZ DEFAULT now()
);
 
-- student_profiles: linked 1:1 with users where role='student'
CREATE TABLE student_profiles (
  id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id     UUID REFERENCES users(id) ON DELETE CASCADE,
  parent_id   UUID REFERENCES users(id),
  name        TEXT NOT NULL,
  grade       INT,
  board       TEXT,            -- CBSE/ICSE/State/IB
  subjects    JSONB,           -- ['Math','Science']
  elo_ratings JSONB DEFAULT '{}',  -- {'Math.Chapter1': 1000, ...}
  onboarded   BOOLEAN DEFAULT false
);
 
-- textbooks: indexed PDFs per student per subject
CREATE TABLE textbooks (
  id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  student_id  UUID REFERENCES student_profiles(id),
  subject     TEXT, grade INT, board TEXT,
  s3_key      TEXT,
  status      TEXT CHECK(status IN ('uploading','indexing','ready','failed')),
  chunk_count INT,
  uploaded_at TIMESTAMPTZ DEFAULT now()
);
 
-- sessions: one row per teaching session
CREATE TABLE sessions (
  id           UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  student_id   UUID REFERENCES student_profiles(id),
  subject      TEXT, chapter TEXT,
  started_at   TIMESTAMPTZ DEFAULT now(),
  ended_at     TIMESTAMPTZ,
  duration_min INT,
  transcript   JSONB,         -- [{role, content, ts}]
  elo_delta    JSONB          -- per-chapter ELO changes this session
);
 
-- behavior_incidents: CV detections during sessions
CREATE TABLE behavior_incidents (
  id           UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  session_id   UUID REFERENCES sessions(id),
  student_id   UUID,
  type         TEXT,          -- 'gaze_away','no_face','phone_detected'
  photo_url    TEXT,
  notified_at  TIMESTAMPTZ,
  ts           TIMESTAMPTZ DEFAULT now()
);
 
-- test_results: per-question breakdown
CREATE TABLE test_results (
  id           UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  student_id   UUID,
  subject      TEXT, chapter TEXT,
  score        FLOAT, max_score FLOAT,
  answers      JSONB,         -- [{q_id, earned, max, type, feedback}]
  taken_at     TIMESTAMPTZ DEFAULT now()
);
 
-- Row Level Security (Supabase) — students see ONLY their data
ALTER TABLE sessions ENABLE ROW LEVEL SECURITY;
CREATE POLICY student_own_sessions ON sessions
  USING (student_id = auth.uid());

