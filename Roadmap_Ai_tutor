      'weak_topics':       find_weak_chapters(tests),   # score < 50%
      'strong_topics':     find_strong_chapters(tests), # score > 80%
      'behavior_score':    compute_behavior_score(behavior), # 0-100
      'elo_by_chapter':    get_elo_map(student_id),
      'updated_at':        datetime.utcnow().isoformat()
    }
    # Store as single JSON — dashboard loads in <100ms
    update_student_metrics_cache(student_id, metrics)

