Frame sent to server only every 5 seconds. Server-side YOLOv8 — confidence threshold 0.65+.

Optimized Browser Detection (Web Worker)
// frontend/workers/behaviorWorker.ts
// Runs entirely off main thread — UI never blocks
import { FaceMesh } from '@mediapipe/face_mesh'
 
const GAZE_THRESHOLD_FRAMES = 10   // 10s at 1fps
const NOFACE_THRESHOLD_FRAMES = 3  // 3s at 1fps
 
let gazeCount = 0, nofaceCount = 0
 
function handleResults(results) {
  if (!results.multiFaceLandmarks?.length) {
    if (++nofaceCount >= NOFACE_THRESHOLD_FRAMES)
      self.postMessage({ type: 'incident', kind: 'no_face' })
    return
  }
  nofaceCount = 0
  const score = computeGazeScore(results.multiFaceLandmarks[0])
  if (score < 0.35) {
    if (++gazeCount >= GAZE_THRESHOLD_FRAMES)
      self.postMessage({ type: 'incident', kind: 'gaze_away' })
  } else {
    gazeCount = 0
  }
}
 
// Main thread posts ImageBitmap to worker — zero copy transfer
self.onmessage = async ({ data: { frame } }) => {
  await faceMesh.send({ image: frame })
}

