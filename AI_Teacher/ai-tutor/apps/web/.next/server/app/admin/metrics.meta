{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/admin/layout,_N_T_/admin/metrics/layout,_N_T_/admin/metrics/page,_N_T_/admin/metrics"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/admin/metrics/__PAGE__",
    "/admin/metrics",
    "/admin",
    "/_index",
    "/_head"
  ]
}