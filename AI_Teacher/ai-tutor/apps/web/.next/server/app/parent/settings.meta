{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/parent/layout,_N_T_/parent/settings/layout,_N_T_/parent/settings/page,_N_T_/parent/settings"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/parent/settings/__PAGE__",
    "/parent/settings",
    "/parent",
    "/_index",
    "/_head"
  ]
}